NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe (test mode) — Checkout subscription for Pro
# Must be the Secret key (sk_test_...), NOT the Publishable key (pk_test_...).
# Windows: if STRIPE_SECRET_KEY is set in User/System env vars, it overrides this file.
STRIPE_SECRET_KEY=sk_test_...
# Stripe Price ids (Dashboard → Products → each price)
STRIPE_PRICE_ID_BASIC=price_...
# Pro: prefer STRIPE_PRICE_ID_PRO; STRIPE_PRICE_ID is still supported as a fallback.
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID=price_...
# Webhook signing secret (Dashboard → Developers → Webhooks → Signing secret, whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook events: checkout.session.completed, invoice.payment_succeeded,
# customer.subscription.updated, customer.subscription.deleted
# Enable Stripe Customer Portal (Dashboard → Settings → Billing → Customer portal) so users can cancel at period end.
# Service role: required for webhook handler to update `subscriptions` (no user session / RLS).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: used if Origin header is missing (e.g. some server-side calls)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
